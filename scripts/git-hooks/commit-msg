#!/bin/sh

# commit-msg <MSG_FILE>

MSG_FILE="$1"
MSG_CONTENT=$(cat "$MSG_FILE")

# 주석 제외한 실질 메시지
RAW_MSG=$(printf '%s\n' "$MSG_CONTENT" | grep -vE '^[[:space:]]*#')

# 이미 [ABC-123] 형태의 Jira 키가 맨 앞에 있으면 통과
if printf '%s\n' "$RAW_MSG" | grep -Eq '^[[][A-Z][A-Z0-9_-]*-[0-9]+[]]'; then
  exit 0
fi

echo "⚠️ Commit message has no Jira key prefix. Trying to infer from branch..."

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || {
  echo "❌ Cannot determine git branch. Please add Jira key manually, e.g., [MOM-123] ..."
  exit 1
}

REST=$(printf '%s\n' "$BRANCH" | cut -d'/' -f2-)

# REST 예시: MOM-144-사용자는-회원탈퇴를-할-수-있어야-한다
JIRA_KEY_PREFIX=$(printf '%s\n' "$REST" | cut -d'-' -f1)  # MOM
JIRA_KEY_NUM=$(printf '%s\n' "$REST" | cut -d'-' -f2)     # 144

if [ -z "$JIRA_KEY_PREFIX" ] || [ -z "$JIRA_KEY_NUM" ]; then
  echo "❌ Could not infer Jira key from branch. Expected something like: prefix/MOM-123-some-title"
  echo "   Please edit commit message to start with [MOM-123] style Jira key."
  exit 1
fi

JIRA_KEY="${JIRA_KEY_PREFIX}-${JIRA_KEY_NUM}"

NON_COMMENT_LINES=$(printf '%s\n' "$MSG_CONTENT" | sed '/^[[:space:]]*#/d')
COMMENT_LINES=$(printf '%s\n' "$MSG_CONTENT" | sed -n '/^[[:space:]]*#/p')

FIRST_LINE=$(printf '%s\n' "$NON_COMMENT_LINES" | sed -n '1p')
REST_LINES=$(printf '%s\n' "$NON_COMMENT_LINES" | sed '1d')

TRIMMED_FIRST=$(printf '%s\n' "$FIRST_LINE" | tr -d '[:space:]')

{
  if [ -z "$TRIMMED_FIRST" ]; then
    printf '[%s]\n' "$JIRA_KEY"
  else
    printf '[%s] %s\n' "$JIRA_KEY" "$FIRST_LINE"
    if [ -n "$REST_LINES" ]; then
      printf '%s\n' "$REST_LINES"
    fi
  fi

  if [ -n "$COMMENT_LINES" ]; then
    printf '\n%s\n' "$COMMENT_LINES"
  fi
} > "${MSG_FILE}.tmp"

mv "${MSG_FILE}.tmp" "$MSG_FILE"

echo "✅ Commit message updated with Jira key:"
head -n 1 "$MSG_FILE"
