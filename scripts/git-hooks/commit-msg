#!/bin/sh

MSG_FILE="$1"
MSG_CONTENT=$(cat "$MSG_FILE")

# 규칙에 맞으면 통과
if echo "$MSG_CONTENT" | grep -Eq '^\[[A-Z][A-Z0-9_-]*-[0-9]+\]\s+(feat|fix|hotfix|refactor|docs|test|chore|rename|remove):\s+.+'; then
  exit 0
fi

echo "⚠️ Commit message does not match convention. Trying auto-fix..."

BRANCH=$(git rev-parse --abbrev-ref HEAD)

PREFIX=$(echo "$BRANCH" | cut -d'/' -f1)
REST=$(echo "$BRANCH" | cut -d'/' -f2-)

# REST = MOM-144-사용자는-회원탈퇴를-할-수-있어야-한다
JIRA_KEY_PREFIX=$(echo "$REST" | cut -d'-' -f1)  # MOM
JIRA_KEY_NUM=$(echo "$REST" | cut -d'-' -f2)     # 144
RAW_TITLE=$(echo "$REST" | cut -d'-' -f3-)       # 사용자는-회원탈퇴를-할-수-있어야-한다

if [ -z "$JIRA_KEY_PREFIX" ] || [ -z "$JIRA_KEY_NUM" ] || [ -z "$RAW_TITLE" ]; then
  echo "❌ Missing Jira key or title (branch must look like: prefix/MOM-144-some-title)"
  exit 1
fi

JIRA_KEY="${JIRA_KEY_PREFIX}-${JIRA_KEY_NUM}"

COMMIT_PREFIX="$PREFIX"
[ "$PREFIX" = "bugfix" ] && COMMIT_PREFIX="fix"

# 기존 메시지에서 주석 제거
RAW_MSG=$(echo "$MSG_CONTENT" | grep -vE '^\s*#')

# 사용자가 쓴 내용이 있으면 그대로 summary로 사용, 없으면 브랜치 타이틀 사용
if [ -n "$(echo "$RAW_MSG" | tr -d '[:space:]')" ]; then
  SUMMARY="$RAW_MSG"
else
  SUMMARY=$(echo "$RAW_TITLE" | tr '_' ' ')
fi

NEW_MSG="[$JIRA_KEY] $COMMIT_PREFIX: $SUMMARY"

echo "$NEW_MSG" > "$MSG_FILE"
echo "✅ Fixed:"
echo "   $NEW_MSG"
