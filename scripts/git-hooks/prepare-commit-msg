#!/bin/sh

# prepare-commit-msg <MSG_FILE> <COMMIT_SOURCE> <SHA1>

MSG_FILE="$1"
COMMIT_SOURCE="$2"

# merge, squash, 템플릿 기반 커밋(commit)은 자동 생성 스킵
case "$COMMIT_SOURCE" in
  merge|squash|commit)
    exit 0
    ;;
esac

# 이미 유의미한 메시지가 있으면 건드리지 않음
STRIPPED_MSG=$(grep -vE '^[[:space:]]*#' "$MSG_FILE" | tr -d '[:space:]')
if [ -n "$STRIPPED_MSG" ]; then
  exit 0
fi

# 브랜치에서 Jira 키 추출
BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null) || exit 0

REST=$(printf '%s\n' "$BRANCH" | cut -d'/' -f2-)

# REST 예시: MOM-144-사용자는-회원탈퇴를-할-수-있어야-한다
JIRA_KEY_PREFIX=$(printf '%s\n' "$REST" | cut -d'-' -f1)  # MOM
JIRA_KEY_NUM=$(printf '%s\n' "$REST" | cut -d'-' -f2)     # 144

# 형식이 안 맞으면 그냥 스킵
if [ -z "$JIRA_KEY_PREFIX" ] || [ -z "$JIRA_KEY_NUM" ]; then
  exit 0
fi

JIRA_KEY="${JIRA_KEY_PREFIX}-${JIRA_KEY_NUM}"

{
  printf '[%s] \n\n' "$JIRA_KEY"
  cat "$MSG_FILE"
} > "${MSG_FILE}.tmp"

mv "${MSG_FILE}.tmp" "$MSG_FILE"