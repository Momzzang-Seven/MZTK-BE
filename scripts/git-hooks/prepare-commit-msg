#!/bin/sh

MSG_FILE="$1"
COMMIT_SOURCE="$2"
SHA1="$3"

# merge, squash, --amend 등은 자동 생성 스킵
case "$COMMIT_SOURCE" in
  merge|squash|commit)
    exit 0
    ;;
esac

# 이미 유의미한 메시지가 있으면 그대로 사용
STRIPPED_MSG=$(grep -vE '^\s*#' "$MSG_FILE" | tr -d '[:space:]')
if [ -n "$STRIPPED_MSG" ]; then
  exit 0
fi

BRANCH=$(git rev-parse --abbrev-ref HEAD)

PREFIX=$(echo "$BRANCH" | cut -d'/' -f1)
REST=$(echo "$BRANCH" | cut -d'/' -f2-)

# REST = MOM-144-사용자는-회원탈퇴를-할-수-있어야-한다 형태라고 가정
JIRA_KEY_PREFIX=$(echo "$REST" | cut -d'-' -f1)  # MOM
JIRA_KEY_NUM=$(echo "$REST" | cut -d'-' -f2)     # 144
RAW_TITLE=$(echo "$REST" | cut -d'-' -f3-)       # 사용자는-회원탈퇴를-할-수-있어야-한다

# 형식이 안 맞으면 그냥 건너뜀
if [ -z "$JIRA_KEY_PREFIX" ] || [ -z "$JIRA_KEY_NUM" ] || [ -z "$RAW_TITLE" ]; then
  exit 0
fi

JIRA_KEY="${JIRA_KEY_PREFIX}-${JIRA_KEY_NUM}"

COMMIT_PREFIX="$PREFIX"
[ "$PREFIX" = "bugfix" ] && COMMIT_PREFIX="fix"

# 브랜치 타이틀에서 언더스코어만 공백으로 (하이픈은 그대로 유지)
TITLE=$(echo "$RAW_TITLE" | tr '_' ' ')

GENERATED_MSG="[$JIRA_KEY] $COMMIT_PREFIX: $TITLE"

echo "$GENERATED_MSG" > "$MSG_FILE"
