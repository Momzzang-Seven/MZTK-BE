SPRING_PROFILES_ACTIVE=dev

DB_URL=
DB_URL_E2E=
DB_URL_PROD=
DB_USERNAME=
DB_PASSWORD=

JWT_SECRET=

# PostgreSQL 기본 설정
POSTGRES_CONTAINER_NAME=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# 포트
POSTGRES_PORT=

# 볼륨 & 네트워크 이름
POSTGRES_VOLUME_NAME=
PROJECT_NETWORK=

# 소셜 로그인
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=
KAKAO_ADMIN_KEY=
KAKAO_REST_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# 프로덕션 도메인 (CORS, EIP-4361 uri 등에 사용)
PROD_DOMAIN=
TEST_DOMAIN=

# MZTK
## COMMON SETTINGS
TREASURY_ETH_WARNING_THRESHOLD=
TREASURY_ETH_CRITICAL_THRESHOLD=

# WEB3 검색기
WEB3_EXPLORER_BASE_URL=
WEB3_EXPLORER_API_URL=
WEB3_EXPLORER_API_KEY=

# MZTK 배포 환경
WEB3_CHAIN_ID=
WEB3_RPC_MAIN=
WEB3_RPC_SUB=
MZTK_TOKEN_CONTRACT_ADDRESS=

# EIP-712 설정
WEB3_EIP712_VERIFYING_CONTRACT=

# EIP-7702 설정
WEB3_EIP7702_DELEGATION_CONTRACT_ADDRESS=
WEB3_EIP7702_NONCE_TRACKER_ADDRESS=
WEB3_EIP7702_BATCH_IMPL_ADDRESS=
WEB3_EIP7702_DEFAULT_RECEIVER_ADDRESS=

# EIP-7702 스폰서 지갑 설정
WEB3_TREASURY_PROVISIONING_ENABLED=

# Web3 execution toggles
WEB3_EXECUTION_INTERNAL_ENABLED=true
WEB3_EXECUTION_INTERNAL_ACTION_POLICY=QNA_AND_MARKETPLACE_ADMIN
WEB3_EIP_7702_ENABLED=true
WEB3_QNA_ADMIN_ENABLED=true
WEB3_QNA_AUTO_ACCEPT_ENABLED=true
WEB3_MARKETPLACE_ADMIN_ENABLED=true
WEB3_MARKETPLACE_ADMIN_FAIL_FAST=true
WEB3_MARKETPLACE_ADMIN_AUTO_SETTLE_ENABLED=false
WEB3_MARKETPLACE_ADMIN_AUTO_SETTLE_BATCH_SIZE=50
WEB3_MARKETPLACE_ADMIN_AUTO_SETTLE_SCAN_SIZE=150
WEB3_MARKETPLACE_ADMIN_AUTO_SETTLE_MAX_SCAN_PAGES_PER_BATCH=5
WEB3_MARKETPLACE_ADMIN_AUTO_SETTLE_MAX_BATCHES_PER_RUN=20
WEB3_MARKETPLACE_ADMIN_AUTO_SETTLE_CRON="0 23 * * * *"
WEB3_MARKETPLACE_ADMIN_AUTO_SETTLE_ZONE=Asia/Seoul
WEB3_MARKETPLACE_ADMIN_RECOVERY_ENABLED=true
WEB3_MARKETPLACE_ADMIN_RECOVERY_BATCH_SIZE=100
WEB3_MARKETPLACE_ADMIN_RECOVERY_MAX_BATCHES_PER_RUN=20
WEB3_MARKETPLACE_ADMIN_RECOVERY_CRON="0 */5 * * * *"
WEB3_MARKETPLACE_ADMIN_RECOVERY_ZONE=Asia/Seoul
WEB3_MARKETPLACE_ADMIN_RECONCILIATION_ENABLED=true
WEB3_MARKETPLACE_ADMIN_RECONCILIATION_BATCH_SIZE=100
WEB3_MARKETPLACE_ADMIN_RECONCILIATION_MAX_BATCHES_PER_RUN=20
WEB3_MARKETPLACE_ADMIN_RECONCILIATION_CLAIM_STALE_MINUTES=5
WEB3_MARKETPLACE_ADMIN_RECONCILIATION_CRON="0 */5 * * * *"
WEB3_MARKETPLACE_ADMIN_RECONCILIATION_ZONE=Asia/Seoul

# Marketplace reservation domain schedulers
MARKETPLACE_RESERVATION_ZONE=Asia/Seoul
MARKETPLACE_RESERVATION_AUTO_CANCEL_ENABLED=true
MARKETPLACE_RESERVATION_AUTO_CANCEL_CRON="0 0/30 * * * *"
MARKETPLACE_RESERVATION_AUTO_SETTLE_ENABLED=false
MARKETPLACE_RESERVATION_AUTO_SETTLE_CRON="0 0 * * * *"

# ESCROW 설정
WEB3_ESCROW_MARKETPLACE_CONTRACT_ADDRESS=
WEB3_ESCROW_QNA_CONTRACT_ADDRESS=

# AWS S3 IAM credentials
AWS_S3_BUCKET=
AWS_IAM_ACCESS_KEY=
AWS_IAM_SECRET_KEY=

# Lambda Webhook
LAMBDA_WEBHOOK_SECRET=

GEMINI_API_KEY=

WEB3_ESCROW_MARKETPLACE_DEFAULT_DEADLINE_SECONDS=

WEB3_SPONSOR_NONCE_OPEN_WINDOW_SIZE=3
# Tracing / Observability
# Zipkin trace sampling rate (0.0 ~ 1.0). 기본 0.1 (10%).
# 부하테스트 중에만 EC2 ~/apps/.env 에 1.0 으로 임시 override.
TRACING_SAMPLING_PROBABILITY=0.1
