{
  "type": "object",
  "required": [
    "workoutRecord",
    "rejectionReasonCode",
    "dateVisible",
    "exerciseDate",
    "confidenceScore"
  ],
  "properties": {
    "workoutRecord": {"type": "boolean"},
    "rejectionReasonCode": {
      "nullable": true,
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "NOT_WORKOUT_RECORD",
            "DATE_NOT_VISIBLE",
            "MISSING_OR_INVALID_DATE",
            "LOW_CONFIDENCE"
          ]
        },
        {"type": "null"}
      ]
    },
    "dateVisible": {"type": "boolean"},
    "exerciseDate": {
      "nullable": true,
      "anyOf": [
        {"type": "string", "description": "YYYY-MM-DD"},
        {"type": "null"}
      ]
    },
    "confidenceScore": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
