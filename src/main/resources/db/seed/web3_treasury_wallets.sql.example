-- Seed: web3_treasury_wallets (DEV ONLY)
--
-- [사용 방법]
--   이 파일을 복사하여 web3_treasury_wallets.sql 을 생성한 뒤
--   플레이스홀더(<...>)를 실제 dev 테스트넷 값으로 교체하세요.
--
--   $ cp web3_treasury_wallets.sql.example web3_treasury_wallets.sql
--
-- [주의]
--   web3_treasury_wallets.sql 은 .gitignore 에 등록되어 있습니다.
--   절대 실제 값이 담긴 파일을 커밋하지 마세요.
--
-- [값 생성 방법 — KMS 시대]
--   treasury_address : Admin API POST /admin/web3/treasury-keys/provision 호출 시
--                      서버가 KMS 로 생성한 keypair 의 공개키로부터 derive 한 EVM 주소.
--   kms_key_id       : 동 endpoint 가 KMS 에서 생성한 CMK 의 keyId (UUID 형식).
--   status           : 'ACTIVE' (provision 직후 기본값).
--   key_origin       : 'IMPORTED' (KMS Imported key material 만 허용 — V065 CHECK).
--
--   provision 절차:
--     1. POST /admin/web3/treasury-keys/provision { "role": "REWARD" } 또는 { "role": "SPONSOR" }
--     2. 응답 body 의 treasuryAddress / kmsKeyId 를 아래 SQL 의 placeholder 와 교체
--     3. dev DB 에 적용

-- reward-treasury (id=1)
update web3_treasury_wallets
set wallet_alias = 'reward-treasury',
    treasury_address = '<YOUR_DEV_REWARD_TREASURY_ADDRESS>',
    kms_key_id = '<YOUR_DEV_REWARD_KMS_KEY_ID>',
    status = 'ACTIVE',
    key_origin = 'IMPORTED',
    updated_at = current_timestamp
where id = 1
  and '<YOUR_DEV_REWARD_TREASURY_ADDRESS>' like '0x%'
  and length('<YOUR_DEV_REWARD_TREASURY_ADDRESS>') = 42;

insert into web3_treasury_wallets (
    id,
    wallet_alias,
    treasury_address,
    kms_key_id,
    status,
    key_origin,
    created_at,
    updated_at
)
select
    1,
    'reward-treasury',
    '<YOUR_DEV_REWARD_TREASURY_ADDRESS>',
    '<YOUR_DEV_REWARD_KMS_KEY_ID>',
    'ACTIVE',
    'IMPORTED',
    current_timestamp,
    current_timestamp
where not exists (
    select 1
    from web3_treasury_wallets
    where id = 1
)
  and '<YOUR_DEV_REWARD_TREASURY_ADDRESS>' like '0x%'
  and length('<YOUR_DEV_REWARD_TREASURY_ADDRESS>') = 42;

-- sponsor-treasury (id=2)
--   ProbeExecutionSignerCapabilityService.execute() 가 sponsor-treasury alias 로
--   probe 하므로, 이 row 가 없으면 dev 부팅 시 QnaAdmin Health DOWN 으로 빠진다.
--   web3.eip7702.sponsor.enabled=true 환경에서는 반드시 채워야 한다.
update web3_treasury_wallets
set wallet_alias = 'sponsor-treasury',
    treasury_address = '<YOUR_DEV_SPONSOR_TREASURY_ADDRESS>',
    kms_key_id = '<YOUR_DEV_SPONSOR_KMS_KEY_ID>',
    status = 'ACTIVE',
    key_origin = 'IMPORTED',
    updated_at = current_timestamp
where id = 2
  and '<YOUR_DEV_SPONSOR_TREASURY_ADDRESS>' like '0x%'
  and length('<YOUR_DEV_SPONSOR_TREASURY_ADDRESS>') = 42;

insert into web3_treasury_wallets (
    id,
    wallet_alias,
    treasury_address,
    kms_key_id,
    status,
    key_origin,
    created_at,
    updated_at
)
select
    2,
    'sponsor-treasury',
    '<YOUR_DEV_SPONSOR_TREASURY_ADDRESS>',
    '<YOUR_DEV_SPONSOR_KMS_KEY_ID>',
    'ACTIVE',
    'IMPORTED',
    current_timestamp,
    current_timestamp
where not exists (
    select 1
    from web3_treasury_wallets
    where id = 2
)
  and '<YOUR_DEV_SPONSOR_TREASURY_ADDRESS>' like '0x%'
  and length('<YOUR_DEV_SPONSOR_TREASURY_ADDRESS>') = 42;
