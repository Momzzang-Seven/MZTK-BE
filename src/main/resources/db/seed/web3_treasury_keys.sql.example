-- Seed: web3_treasury_keys (DEV ONLY)
--
-- [사용 방법]
--   이 파일을 복사하여 web3_treasury_keys.sql 을 생성한 뒤
--   플레이스홀더(<...>)를 실제 dev 테스트넷 값으로 교체하세요.
--
--   $ cp web3_treasury_keys.sql.example web3_treasury_keys.sql
--
-- [주의]
--   web3_treasury_keys.sql 은 .gitignore 에 등록되어 있습니다.
--   절대 실제 값이 담긴 파일을 커밋하지 마세요.
--
-- [값 생성 방법]
--   treasury_address        : 테스트넷 전용 Ethereum 지갑 주소 (0x로 시작, 42자)
--   treasury_private_key_encrypted :
--       Admin API POST /admin/web3/treasury-keys/provision 를 호출하면
--       서버가 KEK로 암호화한 값을 DB에 직접 저장합니다.
--       또는 로컬에서 ProvisionTreasuryKeyService 를 통해 생성된 암호문을 사용하세요.

update web3_treasury_keys
set wallet_alias = 'reward-treasury',
    treasury_address = '<YOUR_DEV_TREASURY_ADDRESS>',
    treasury_private_key_encrypted = '<YOUR_DEV_ENCRYPTED_PRIVATE_KEY>',
    updated_at = current_timestamp
where id = 1
  and '<YOUR_DEV_TREASURY_ADDRESS>' like '0x%'
  and length('<YOUR_DEV_TREASURY_ADDRESS>') = 42
  and position('.' in '<YOUR_DEV_ENCRYPTED_PRIVATE_KEY>') > 1;

insert into web3_treasury_keys (
    id,
    wallet_alias,
    treasury_address,
    treasury_private_key_encrypted,
    created_at,
    updated_at
)
select
    1,
    'reward-treasury',
    '<YOUR_DEV_TREASURY_ADDRESS>',
    '<YOUR_DEV_ENCRYPTED_PRIVATE_KEY>',
    current_timestamp,
    current_timestamp
where not exists (
    select 1
    from web3_treasury_keys
    where id = 1
)
  and '<YOUR_DEV_TREASURY_ADDRESS>' like '0x%'
  and length('<YOUR_DEV_TREASURY_ADDRESS>') = 42
  and position('.' in '<YOUR_DEV_ENCRYPTED_PRIVATE_KEY>') > 1;
