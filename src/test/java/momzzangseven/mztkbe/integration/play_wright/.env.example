# ============================================================
# MZTK Playwright E2E - 환경 변수 템플릿
#
# 이 파일을 복사하여 .env 로 이름을 바꾼 뒤 실제 값을 입력하세요.
# .env 파일은 .gitignore 에 의해 커밋되지 않습니다.
# ============================================================

# ---------------------------
# 백엔드 서버 (로컬 Spring Boot)
# ---------------------------
# macOS에서 localhost 는 IPv6(::1)로 resolve되어 Spring Boot(IPv4)와 연결이 거부될 수 있음
# → 반드시 127.0.0.1 로 지정할 것
BACKEND_URL=

# ---------------------------
# Web3 / QnA Escrow Playwright 설정
# ---------------------------
WEB3_RPC_URL=
WEB3_EIP712_DOMAIN_NAME=MomzzangSeven
WEB3_EIP712_DOMAIN_VERSION=1
WEB3_EIP712_CHAIN_ID=
WEB3_EIP712_VERIFYING_CONTRACT=
WEB3_ESCROW_QNA_CONTRACT_ADDRESS=
WEB3_REWARD_TOKEN_CONTRACT_ADDRESS=
WEB3_REWARD_TOKEN_DECIMALS=18

# funded test wallets for real QnA escrow Playwright flow
# - asker: reward token allowance approve + question execute
# - responder: answer intent creation / execute
QNA_TEST_ASKER_PRIVATE_KEY=
QNA_TEST_RESPONDER_PRIVATE_KEY=

# optional dedicated wallets for TRANSFER_SEND on-chain flow
# if omitted, Playwright falls back to the QnA test wallets above
TRANSFER_TEST_SENDER_PRIVATE_KEY=
TRANSFER_TEST_RECIPIENT_PRIVATE_KEY=

# ---------------------------
# Kakao OAuth 설정
# ---------------------------
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=

# Kakao 테스트 계정 (카카오 개발자 앱에 등록된 테스터 계정)
KAKAO_TEST_EMAIL=
KAKAO_TEST_PASSWORD=

# ---------------------------
# Google OAuth 설정
# ---------------------------
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=

# Google 테스트 계정 (GCP OAuth 앱에 등록된 테스트 유저)
GOOGLE_TEST_EMAIL=
GOOGLE_TEST_PASSWORD=

# ---------------------------
# Kakao Geocoding API 설정
# ---------------------------
KAKAO_REST_API_KEY=

# ---------------------------
# Local DB 설정 (Playwright fixture / 검증용)
# ---------------------------
# DATABASE_URL 이 있으면 아래 개별 값보다 우선 사용합니다.
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# ---------------------------
# Workout Verification Playwright 자산 설정
# ---------------------------
# 아래 자산은 실제 S3 업로드 + 실제 verification submit 에 사용됩니다.
# photo approved:
#   - 오늘(Asia/Seoul) 촬영 EXIF 가 포함된 운동 사진
# record approved:
#   - 오늘 날짜가 보이는 승인용 운동 기록 캡처
# record rejected:
#   - 거절이 재현되는 비운동/날짜불일치 운동 기록 캡처
VERIFICATION_PHOTO_APPROVED_IMAGE=
VERIFICATION_RECORD_APPROVED_IMAGE=
VERIFICATION_RECORD_REJECTED_IMAGE=

# ---------------------------
# Lambda Webhook Secret
# ---------------------------
# 서버의 lambda.webhook.secret (LAMBDA_WEBHOOK_SECRET 환경변수) 과 동일한 값을 입력하세요.
LAMBDA_WEBHOOK_SECRET=

# ---------------------------
# Admin 계정 설정 (MOM-330 admin-user-role-management Playwright 테스트용)
# ---------------------------
# 부트스트랩 완료 후 전달 메커니즘(LOG 또는 AWS Secrets Manager)에서 확인한 seed admin 자격증명을 입력하세요.
ADMIN_LOGIN_ID=
ADMIN_PASSWORD=

# Recovery anchor — application.properties 또는 AWS Secrets Manager 에 설정된 값과 동일하게 입력하세요.
RECOVERY_ANCHOR=

# ---------------------------
# Treasury wallet provisioning/disable/archive
# ---------------------------
TREASURY_E2E_PRIVATE_KEY=<테스트용 지갑 private key (32바이트 hex)>
TREASURY_E2E_EXPECTED_ADDRESS=<위 키로 파생된 주소>
DB_HOST=localhost
DB_NAME=mztk_dev   # prod 서버가 붙는 DB와 동일하게
DB_USER=...
DB_PASSWORD=...
SKIP_KMS_PROVISION=false