# ============================================================
# MZTK Playwright E2E - 환경 변수 템플릿
#
# 이 파일을 복사하여 .env 로 이름을 바꾼 뒤 실제 값을 입력하세요.
# .env 파일은 .gitignore 에 의해 커밋되지 않습니다.
# ============================================================

# ---------------------------
# 백엔드 서버 (로컬 Spring Boot)
# ---------------------------
# macOS에서 localhost 는 IPv6(::1)로 resolve되어 Spring Boot(IPv4)와 연결이 거부될 수 있음
# → 반드시 127.0.0.1 로 지정할 것
BACKEND_URL=http://127.0.0.1:8080

# ---------------------------
# Kakao OAuth 설정
# ---------------------------
KAKAO_CLIENT_ID=bac9e0d526d96cd190eb972238209c42
KAKAO_REDIRECT_URI=http://localhost:3000/callback

# Kakao 테스트 계정 (카카오 개발자 앱에 등록된 테스터 계정)
KAKAO_TEST_EMAIL=your-kakao-test@email.com
KAKAO_TEST_PASSWORD=your-kakao-password

# ---------------------------
# Google OAuth 설정
# ---------------------------
GOOGLE_CLIENT_ID=1058525254512-b5lb410om3bq9lgcfqd827ko48t53193.apps.googleusercontent.com
GOOGLE_REDIRECT_URI=http://localhost:3000/callback

# Google 테스트 계정 (GCP OAuth 앱에 등록된 테스트 유저)
GOOGLE_TEST_EMAIL=your-google-test@gmail.com
GOOGLE_TEST_PASSWORD=your-google-password

# ---------------------------
# Kakao Geocoding API 설정
# ---------------------------
KAKAO_REST_API_KEY=kakao-rest-api-key